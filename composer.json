{
    "name": "rubricate/relevant",
    "description": "A minimalist, expressively-routed controller and middleware lifecycle manager for modern MVC applications.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Estefanio N Santos",
            "email": "estefanions@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "rubricate/uri": "^4.1"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.10",
        "phpunit/phpunit": "^10.0"
    },
    "keywords": [
        "rubricate",
        "relevant",
        "controller",
        "middleware",
        "mvc",
        "routing",
        "lifecycle"
    ],
    "support": {
        "docs": "https://rubricate.github.io/components/relevant",
        "source": "https://github.com/rubricate/relevant",
        "issues": "https://github.com/rubricate/relevant/issues"
    },
    "autoload": {
        "psr-4": {
            "Rubricate\\Relevant\\": "Rubricate/Relevant/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "platform": {
            "php": "8.2"
        },
        "sort-packages": true
    }
}

